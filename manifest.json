{
  "manifest_version": 3,
  "name": "CF Gyms Statement Exporter",
  "short_name": "CF Gyms Export",
  "version": "0.2.2",
  "description": "Export Codeforces contest, Gym, and group contest statements to clean PDFs by ICPC Assiut.",
  "homepage_url": "https://icpcassiut.org",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {
    "default_title": "Export CF statements",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://codeforces.com/*"],
      "js": ["src/content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "debugger", "downloads", "storage"],
  "host_permissions": [
    "https://codeforces.com/*",
    "https://espresso.codeforces.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' data: https://codeforces.com https://espresso.codeforces.com; style-src 'self' 'unsafe-inline'"
  }
}
